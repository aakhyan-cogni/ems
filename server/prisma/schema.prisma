generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

enum Gender {
    Male
    Female
    Others
}

model User {
    id             String  @id @default(auto()) @map("_id") @db.ObjectId
    email          String  @unique
    password       String // hashed password here
    name           String
    avatar         String  @default("default.png")
    phoneNumber    String?
    dob            String?
    gender         Gender?
    country        String?
    city           String?
    state          String?
    zipcode        String?
    orgName        String?
    designation    String?
    companyWebsite String?
    bio            String?

    // --- Simple JWT Auth Fields ---
    // Store the refresh token (or its hash) to validate refresh requests
    refreshToken String?
    role         String? @default("user")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relation: A user can organize many events
    events Event[]
}

model Event {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    title       String
    category    String
    description String
    tags        String[]
    imgUrls     String[]
    date        DateTime
    location    String
    price       Float    @default(0.0)
    capacity    Int

    // Relation logic
    organizerId String @db.ObjectId
    organizer   User   @relation(fields: [organizerId], references: [id])

    // Kept from your Zustand store for easy frontend access
    organizerEmail String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
